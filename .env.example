# AI Trip Planner — Environment Variables
# Copy this to .env and fill in your real values.
# NEVER commit .env — it is in .gitignore.

# Supabase (Used by Next.js Frontend & FastAPI Backend)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key-here   # Use service_role key for backend in production

# AI & LLM Keys
GROQ_API_KEY=gsk_...
GOOGLE_GEMINI_API_KEY=

# Backend API Keys (Weather, Flight, Hotels)
OPENWEATHER_API_KEY=
LITEAPI_API_KEY=
OPENTRIPMAP_API_KEY=
AVIATIONSTACK_API_KEY=
NEWSAPI_KEY=
ADMIN_SECRET=your-strong-admin-secret-here

# NextJS Frontend & FastAPI Backend Communication
NEXT_JS_ORIGIN=http://localhost:3000
PYTHON_BACKEND_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
INTERNAL_API_TOKEN=your-strong-internal-token-here

# Media Assets & Unsplash
UNSPLASH_ACCESS_KEY=
